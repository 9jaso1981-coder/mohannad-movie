name: mohannad_movie
description: Public Domain movie, TV & classic film streaming app (no login, no licensing required)
publish_to: 'none'
version: 1.0.0+1

environment:
  sdk: '>=3.3.0 <4.0.0'

dependencies:
  flutter:
    sdk: flutter

  # State Management
  flutter_bloc: ^8.1.6
  equatable: ^2.0.5

  # Dependency Injection
  get_it: ^7.7.0

  # Networking (Internet Archive API - no key required)
  dio: ^5.6.0
  connectivity_plus: ^6.0.5

  # Video Player
  media_kit: ^1.1.11
  media_kit_video: ^1.2.5
  media_kit_libs_video: ^1.0.5
  wakelock_plus: ^1.2.8

  # Subtitles (public domain subs are often bundled directly on archive.org item pages)
  archive: ^3.6.1

  # Local storage (favorites / continue-watching - fully on-device, no account)
  hive: ^2.2.3
  hive_flutter: ^1.1.0
  cached_network_image: ^3.4.1

  # UI
  cupertino_icons: ^1.0.8
  shimmer: ^3.0.0
  google_fonts: ^6.2.1
  flutter_svg: ^2.0.10
  dartz: ^0.10.1

dev_dependencies:
  flutter_test:
    sdk: flutter
  build_runner: ^2.4.13
  hive_generator: ^2.0.1
  flutter_lints: ^4.0.0

flutter:
  uses-material-design: true
  assets:
    - assets/icons/
